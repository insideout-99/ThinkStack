GEMINI_API_KEY=

# Optional. Enables PostgreSQL document records, ingestion events, query logs, and feedback.
# Example:
# DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/thinkstack
DATABASE_URL=
DATABASE_CONNECT_TIMEOUT_SECONDS=3

# Optional. Relative paths are resolved from backend/.
QDRANT_PATH=data/qdrant

# Maximum accepted upload size, in bytes (default: 25 MiB).
MAX_UPLOAD_BYTES=26214400

# Comma-separated browser origins. Never use * with credentialed production traffic.
CORS_ORIGINS=http://localhost:5173
